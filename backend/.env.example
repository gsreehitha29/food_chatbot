# =============================================================
# ENVIRONMENT VARIABLES FOR FOOD CHATBOT & SEARCH BACKEND
# =============================================================

# MongoDB connection settings
MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/?appName=<APP_NAME>
DATABASE_NAME=chatbot_db

# Google Gemini API configuration
# (MANDATORY: Obtain an API key from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
EMBEDDING_MODEL=models/text-embedding-004
LLM_MODEL=gemini-1.5-flash

# Qdrant Vector DB Configuration
# (Optional: If empty, client will fall back to an in-memory instance)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=food_menu_items

# Redis Caching Configuration
# (Optional: If empty/fails, client will fall back to local memory dict caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600

# Multi-factor Food Scorer Weights (Sum should ideally be 1.0)
WEIGHT_SEMANTIC=0.4
WEIGHT_REVIEW=0.2
WEIGHT_MENU_RATING=0.2
WEIGHT_RESTAURANT_RATING=0.1
WEIGHT_AVAILABILITY=0.1

# Order Processing Constants (FIX #13)
DELIVERY_FEE=40.0
TAX_RATE=0.05
